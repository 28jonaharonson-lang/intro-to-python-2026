def slot():
    global wallet
    os.system('cls' if os.name == 'nt' else 'clear')
    print ("wallet: {}".format(wallet) + "$")
    if wallet > 0:
        textDelay1("You go to the slot machine, and there are two different prizes: the minor prize where two numbers are the same, and the jackpot where all three numbers are the same. The minor prize pays out 3x, and the jackpot pays out 50x. Type how much moneyyou want to spend. (in dollars)")
        choice = input().strip().lower()
        if int(choice) > int(wallet):
            textDelay1("You do not have that much money.")
            time.sleep(2)
            slot()
        elif int(wallet) >= int(choice):
            slot1 = random.randint(1, 9)
            slot2 = random.randint(1, 9)
            slot3 = random.randint(1, 9)  
            textDelay2(str(slot1) + str(slot2) + str(slot3))
            if slot1 == slot2 and slot2 == slot3:
                wallet = int(choice)*50
                textDelay1("You won the jackpot! You won {}".format(int(choice)*50) + "$")
                time.sleep(3)
                slot()
            elif slot1 == slot2 or slot2 == slot3 or slot1 == slot3:
                wallet = int(choice)*3
                textDelay1("You won the minor prize! You won {}".format(int(choice)*3) + "$")
                time.sleep(3)
                slot()
            else:
                wallet = wallet - int(choice)
                textDelay1("You won nothing. You lost {}".format(choice) + "$")
                time.sleep(2)
                slot()
        else:
            textDelay1("Sorry, I don't understand that.")
            time.sleep(2)
            slot()
    else:
        textDelay1("Unfortunately, you've gone bankrupt. You lose!")
        time.sleep(2)
        enter()
    
    
 

    
    
    
