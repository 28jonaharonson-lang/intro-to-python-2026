import os, time, random

def textDelay1(text, delay=0.001):
    for char in text:
        print(char, end='', flush=True)
        time.sleep(delay)
    print() 


def textDelay2(text, delay=1):
    for char in text:
        print(char, end='', flush=True)
        time.sleep(delay)
    print() 



