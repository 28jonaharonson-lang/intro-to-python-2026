            if slot1 == slot2 and slot2 == slot3:
                wallet = int(choice)*50
                textDelay1("You won the jackpot! You won {}".format(int(choice)*50) + "$")
                time.sleep(3)
                slot()
            elif slot1 == slot2 or slot2 == slot3 or slot1 == slot3:
                wallet = int(choice)*3
                textDelay1("You won the minor prize! You won {}".format(int(choice)*3) + "$")
